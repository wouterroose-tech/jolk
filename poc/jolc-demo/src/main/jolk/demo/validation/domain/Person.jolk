package demo.validation.domain;

///
/// @author Wouter Roose

public class Person {
    Long ssn;
    String firstName;
    String lastName;

    String name() {
        ^ #firstName + " "+ #lastName
    }

    String toString() {
        ^ "Person[ssn=" + #ssn + ", firstName=" + #firstName + ", lastName=" + #lastName + "]"
    }

    Boolean ~~(Object other) {
        (self == other) ? [ ^true ];
        other #instanceOf(Person) #ifPresent [ p -> 
            ^ (#ssn == p #ssn)
                && (#firstName ~~ p #firstName)
                && (#lastName ~~ p #lastName)
            ];
        ^ false
    }
}