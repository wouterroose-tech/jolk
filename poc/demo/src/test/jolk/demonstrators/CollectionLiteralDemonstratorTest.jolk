~ demonstrators;

+ java.util.List;
+ java.util.stream.Collectors;
+ jolk.test.api.TestCase;

///
/// @author Wouter Roose
///
public class CollectionLiteralDemonstratorTest extends TestCase {

    CollectionLiteralDemonstrator demonstrator = CollectionLiteralDemonstrator #new;

    
    testRunArrayLiteral() {
        #assertEquals("a", demonstrator #runArrayLiteral(0))
    }

    testRunArrayLiteralField() {
        #assertEquals("red", demonstrator #runArrayLiteralField(0))
    }

    testRunEmptyArray() {
        #assertEquals(0, demonstrator #runEmptyArray)
    }

    testRunArrayContains() {
        #assertTrue(demonstrator #runArrayContains("red"));
        #assertFalse(demonstrator #runArrayContains("yellow"));
    }

    testRunNestedArray() {
        #assertEquals(1, demonstrator #runNestedArray(0));
    }

    testRunMapLiteral() {
        #assertEquals("#FF0000", demonstrator #runMapLiteral("red"));
    }

    testRunMapLiteralField() {
        #assertEquals("#FF0000", demonstrator #runMapLiteralField("red"));
    }


    testRunMapContainsKey() {
        #assertTrue(demonstrator #runMapContainsKey("red"));
        #assertFalse(demonstrator #runMapContainsKey("yellow"));
    }

    testRunEmptyMapSize() {
        #assertEquals(0, demonstrator #runEmptyMapSize)
    }

    testRunMapSize() {
        #assertEquals(3, demonstrator #runMapSize)
    }

}
