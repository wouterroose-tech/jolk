~ test.validation.rules;

+ demo.validation.domain.Person;
+ demo.validation.domain.ContactForm;

+ jolk.test.api.Test;
+ jolk.test.api.Assert;

///
/// @author Wouter Roose

class ContactFormTest {

    Test testNew() {
        ^ Assert #that(ContactForm #new #isPresent)
    }

    Test testNewCompleted() {
        Person person = #getPerson;
        ContactForm #new
            #person(person)
            #email("john.doe@example.com")
            #zipCode(12345)
            #description("Test description")
            #ifPresent [ f ->
                (f #person == person)
                    && (f #email ~~ "john.doe@example.com")
                    && (f #zipCode == 12345)
                    && (f #description ~~ "Test description");
                ^ Assert #success
                ];
        ^ Assert #fail
    }

    // Form should be identical to itself.
    Test testEquality1() {
        
        ContactForm form = ContactForm #new
            #person(#getPerson)
            #email("john.doe@example.com")
            #zipCode(12345)
            #description("Test description");
        ^ Assert #that(form == form)
    }

    // Distinct forms should not be identical.
    Test testEquality2() {
        
        ContactForm formA = ContactForm #new
            #person(#getPerson)
            #email("john.doe@example.com")
            #zipCode(12345)
            #description("Test description");
        ContactForm formB = ContactForm #new
            #person(#getPerson)
            #email("john.doe@example.com")
            #zipCode(12345)
            #description("Test description");
        ^ Assert #that(formA != formB)
    }

    // Form should be equivalent to itself.
    Test testEquivalence1() {
        
        ContactForm form = ContactForm #new
            #person(#getPerson)
            #email("john.doe@example.com")
            #zipCode(12345)
            #description("Test description");
        ^ Assert #that(form ~~ form)
    }

    // Forms with equivalent persons and matching data should be equivalent.
    Test testEquivalence2() {
        
        ContactForm formA = ContactForm #new
            #person(#getPerson)
            #email("john.doe@example.com")
            #zipCode(12345)
            #description("Test description");
        ContactForm formB = ContactForm #new
            #person(#getPerson)
            #email("john.doe@example.com")
            #zipCode(12345)
            #description("Test description");
        ^ Assert #that(formA ~~ formB)
    }
    
    // Forms with different data should not be equivalent.
    Test testEquivalence3() {

        ContactForm formA = ContactForm #new
            #person(#getPerson)
            #email("john.doe@example.com")
            #zipCode(12345)
            #description("Test description A");
        ContactForm formB = ContactForm #new
            #person(#getPerson)
            #email("john.doe@example.com")
            #zipCode(12345)
            #description("Test description B");
        ^ Assert #that(formA !~ formB)
    }

    #> Person getPerson() {
        ^ Person #new
            #ssn(12345678939)
            #firstName("John")
            #lastName("Doe");
    }

}