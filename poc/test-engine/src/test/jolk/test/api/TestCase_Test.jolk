~ jolk.test.api;

/// # TestCase_Test
///
/// Demonstrator for the Jolk test protocol.
///
/// This class showcases various testing patterns, including assertions,
/// failure injection, success cases, parameterized tests, and assertions against
/// specific conditions and values, all within Jolk's message-passing paradigm.
///
/// @author Wouter Roose
///
class TestCase_Test extends TestCase {

    testTestProtocol() {
        List<String> testProtocol = #class #testProtocol;
        #assertThat(testProtocol #size == 13)
    }

    testSuccess() {
        #success();
    }

    testFail() {
        #assertFailure [ #fail() ]
    }

    testDisabled() {
        #disabled();
    }

    testAssertThat_success() {
        #assertThat(true)
    }
    
    testAssertThat_failure() {
        #assertFailure [ #assertThat(false) ]
    }
    
    testAssertSame_success() {
        String same = "same";
        #assertEquals(same, same)
    }

    testAssertSame_failure() {
        #assertFailure [ #assertSame("~~ nut but ==", "~~ but not ==") ]
    }
    
    testAssertEquals_success() {
        #assertEquals("Hello", "Hello")
    }

    testAssertEquals_failure() {
        #assertFailure [ #assertEquals("Hello", "World") ]
    }

    testAssertIsPresent_success() {
        #assertIsPresent("Hello")
    }

    testAssertIsPresent_failure() {
        #assertFailure [ #assertIsPresent(null) ]
    }

    meta constant List<Int> params = #[1, 2, 3, 4, 5, 6, 7];
    testParameterized() {
        #parameterized(self ##assertPossitive, params)
    }

    assertPossitive(Int i) {
        #assertThat(i > 0)
    }
    
    #> assertFailure(Closure test) {
        test #catch [ AssertionSignal e -> ^ #success() ];
        #fail
    }
}