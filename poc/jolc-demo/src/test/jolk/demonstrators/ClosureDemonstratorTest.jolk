~ demonstrators;

+ jolk.test.api.TestCase;

///
/// @author Wouter Roose
///
public class ClosureDemonstratorTest extends TestCase {
    
    testRunClosureParam() {
        #assertEquals(42, ClosureDemonstrator #new #runClosureParam(42));
        #assertEquals(0, ClosureDemonstrator #new #runClosureParam(1));
    }

    testRunMethodReference_self() {
        #assertEquals(42, ClosureDemonstrator #new #runMethodReference_self(21));
        #assertEquals(0, ClosureDemonstrator #new #runMethodReference_self(0));
    }

    testRunMethodReference_meta() {
        #assertEquals(42, ClosureDemonstrator #new #runMethodReference_meta(21));
        #assertEquals(0, ClosureDemonstrator #new #runMethodReference_meta(0));
    }

    testRunMethodReference_instance() {
        #assertEquals(42, ClosureDemonstrator #new #runMethodReference_instance(21));
        #assertEquals(0, ClosureDemonstrator #new #runMethodReference_instance(0));
    }
    
}
