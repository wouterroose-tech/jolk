~ test.validation.rules;

+ demo.validation.domain.ContactForm;
+ demo.validation.domain.Person;
+ demo.validation.engine.ExecutionContext;
+ demo.validation.rules.SsnConstraint;
+ demo.validation.rules.ContactFormValidation;
+ demo.validation.engine.Issue;
+ demo.validation.engine.Interrupt;

+ jolk.test.api.Test;
+ jolk.test.api.Assert;

/// # SsnConstraintTest
///
/// Test suite for verifying the logic within [SsnConstraint].
///
/// @author Wouter Roose
class SsnConstraintTest extends Test {

    /// Verifies that the `#accept` protocol succeeds for a valid `Person` ssn.
    test_accept_success() {
        ExecutionContext context = ExecutionContext #new;
        Person person = Person #new #ssn(800101035);
        SsnConstraint #new #accept(person, context);
        #assertThat(!context #hasIssue)
    }

    /// Verifies that the `#accept` protocol generates an issue and interrupts for invalid data.
    test_accept_failure() {
        ExecutionContext context = ExecutionContext #new;
        Person person = Person #new #ssn(800101099);
        
        Boolean interrupted = false;
        [ SsnConstraint #new #accept(person, context) ]
            #catch [ Interrupt e -> interrupted = true ];
        
        #assertThat(interrupted && context #hasIssue)
    }

    /// Verifies `satisfiesPreCondition` when an ssn is present (not 0).
    test_satisfiesPreCondition_success() {
        ExecutionContext context = ExecutionContext #new;
        Person person = Person #new #ssn(800101035);
        #assertThat(SsnConstraint #new #satisfiesPreCondition(person, context))
    }

    /// Verifies `satisfiesPreCondition` when the ssn is 0.
    test_satisfiesPreCondition_failure() {
        ExecutionContext context = ExecutionContext #new;
        Person person = Person #new #ssn(0);
        #assertThat(!SsnConstraint #new #satisfiesPreCondition(person, context))
    }

    /// Verifies the protected `isValid` predicate for valid data.
    test_isValid_success() {
        Person person = Person #new #ssn(800101035);
        #assertThat(SsnConstraint #new #isValid(person))
    }

    /// Verifies the protected `isValid` predicate for invalid data.
    test_isValid_failure() {
        Person person = Person #new #ssn(800101099);
        #assertThat(!SsnConstraint #new #isValid(person))
    }

    /// Verifies the internal logic of the SSN calculation.
    test_isValid_logic() {
        // 800101035: (8001010 % 97) is 62. 97 - 62 is 35.
        #assertThat(SsnConstraint #new #isValid(800101035))
    }

    /// Verifies that `getIssue` returns the correct issue identity.
    test_getIssue() {
        ExecutionContext context = ExecutionContext #new;
        Person person = Person #new #ssn(800101035);

        Issue issue = SsnConstraint #new #getIssue(person, context);
        #assertThat(issue #isPresent 
            && issue #message == "SSN_INVALID" 
            && issue #level #isError)
    }

    /// Verifies that the `interrupt` signal is correctly resolved via lens projection.
    test_interrupt() {
        Interrupt signal = SsnConstraint #new #interrupt;
        #assertThat(signal #isPresent && signal == ContactFormValidation #FORM_INTERRUPT)
    }
}