package examples;

/// # ExpressionDemonstrator
///
/// Demonstrates Jolk's expression capabilities.
///
/// * **Null-Coalescing**: The `??` operator provides a concise fallback for null values.
///
/// @author Wouter Roose

final class ExpressionDemonstrator {

    String runNullCoalescing(String s) {
        ^ s ?? "Default"
    }

    String runNullCoalescingChain(String s1, String s2) {
        ^ s1 ?? s2 ?? "Fallback"
    }
}