package demo.validation.services;

///
/// @author Wouter Roose

final class GeoGraphicalService {
    
    public meta constant Array<Integer> MECHELEN = #[2800, 2801, 2811, 2812];

    private meta GeoGraphicalService new() {
        ^ super #new
    }

    // Caching the external service
    public meta constant GeoGraphicalService GGS = GeoGraphicalService #new;

    Boolean exists(Long zipCode) {
        // simulate lookup via DAO
        ^ 1000 < zipCode && zipCode < 9999
    }
}
