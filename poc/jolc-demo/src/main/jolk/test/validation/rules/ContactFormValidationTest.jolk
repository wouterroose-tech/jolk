~ test.validation.rules;

+ demo.validation.domain.Person;
+ demo.validation.domain.ContactForm;
+ demo.validation.engine.Interrupt;
+ demo.validation.engine.ExecutionContext;
+ demo.validation.engine.ValidationSuite;
+ demo.validation.rules.ContactFormValidation;

+ java.lang.System; 

///
/// @author Wouter Roose

class ContactFormValidationTest {

    /// Test case for validating a contact form with valid data
    Boolean test_ValidateContactForm_success() {
        
        // Create a valid contact form
        Person person = Person #new
            #ssn(12345678939)
            #firstName("John")
            #lastName("Doe");
        ContactForm form = ContactForm #new
            #person(person)
            #email("john.doe@example.com")
            #zipCode(2800)
            #description("Test description");
        
        // Create validation context
        ExecutionContext context = ExecutionContext #new;
        
        // Perform validation
        ContactFormValidation #new #validate(form, context);
        ^ ! context #hasIssue
    }

    /// Test that validation fails when ...
    Boolean test_ValidateContactForm_failure() {
        
        // Create an invalid contact form
        Person person = Person #new
            // invaluid SSN that fails the INSS constraint
            #ssn(12345678937)
            #firstName("John")
            #lastName("Doe");
        ContactForm form = ContactForm #new
            #person(person)
            #email("john.doe@example.com")
            #zipCode(12345)
            #description("Test description");
        
        // Create validation context
        ExecutionContext context = ExecutionContext #new;
        
        // Perform validation
        ContactFormValidation #new #validate(form, context);
        ^ context #hasIssue && context #issues #size == 2
    }

    Boolean test_interrupt() {
        ^ ContactFormValidation #FORM_INTERRUPT #instanceOf(Interrupt) #isPresent 
    }
}