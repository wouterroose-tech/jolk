~ test.validation.rules;

+ demo.validation.engine.Issue;
+ demo.validation.engine.Level;

+ jolk.test.api.Test;
+ jolk.test.api.Assert;

/// # IssueTest
///
/// Test suite for verifying the logic within [Issue].
///
/// @author Wouter Roose
class IssueTest extends Test {
    
    /// Verifies that `getIssue` returns a valid issue template.
    test_getIssue() {
        Issue issue = Issue #new(null, "ZIP_INVALID",  Level #ERROR);
        #assertThat(issue #message == "ZIP_INVALID"  && issue #level #isError)
    }

}