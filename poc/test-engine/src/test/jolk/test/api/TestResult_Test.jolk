~ jolk.test.api;

/// # TestResult_Test
///
/// TODO
///
/// @author Wouter Roose
///
class TestResult_Test extends TestCase {

    @Test
    testNew() {
        TestResult result = TestResult #new;
        #assertTrue(result #status #isEmpty);
        #assertEquals("", result #result);
    }

    @Test
    testSuccess() {
        TestResult result = TestResult #success;
        #assertEquals(TestStatus #SUCCESS, result #status);
        #assertEquals("success", result #result);
    }

    @Test
    testFault() {
        RuntimeException a = RuntimeException #new("message");
        TestResult result = TestResult #fault(a) ;
        #assertEquals(TestStatus #FAULT, result #status);
        #assertEquals("fault: message", result #result);
    }

    @Test
    testFailed() {
        // RuntimeException subclassing not implemented
        // AssertionSignal a = AssertionSignal #new("message");
        RuntimeException a = RuntimeException #new("message");
        TestResult result = TestResult #failed(a) ;
        #assertEquals(TestStatus #FAILURE, result #status);
        #assertEquals("failure: message", result #result);
    }

    @Test
    testDisabled() {
        TestResult result = TestResult #disabled;
        #assertEquals(TestStatus #DISABLED, result #status);
        #assertEquals("disabled", result #result);
    }
}