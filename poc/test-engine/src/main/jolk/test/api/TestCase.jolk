~ jolk.test.api;

+ java.lang.String;
+ java.util.List;
+ java.lang.RuntimeException;
& jolk.test.api.DisabledSignal.DISABLED;

/// # TestCase
///
/// A class serving as a Proof of Concept (POC) demonstrator 
/// for the JolkUnit testing framework architecture.
///
/// This implementation unifies test execution, default assertions, and dynamic 
/// metadata configuration within a single object boundary. It leverages Jolk's 
/// zero-parameter, implicit self-return contract to handle orchestration without 
/// relying on static reflection pipelines or declarative annotations.
///
/// ## Future Architecture Note
/// This class is a transitional blueprint designed for initial validation. In 
/// production-grade environments, this monolithic design is replaced by a 
/// stateless `Test` protocol paired with a thread-isolated `TestExecutionContext` 
/// to ensure thread safety and eliminate namespace pollution.
///
/// @author Wouter Roose
///
class TestCase extends Test {
    
    meta beforeAll() {} 
    
    beforeEach() {} 

    afterEach() {}

    meta afterAll() {}

    disabled() {
        DisabledSignal #DISABLED #throw
    }

    disabled(Boolean condition) {
        condition ? [#disabled]
    }

    success() {}

    fail() {
        #throw("Test Failure: Invariant did not hold")
    }

    assertTrue(Boolean condition) {
        condition ?! [ #throw("Assertion Mismatch: Expected True") ]
    }
    
    assertFalse(Boolean condition) {
        condition ? [ #throw("Assertion Mismatch: Expected False") ]
    }

    assertSame(Object expected, Object actual) {
        actual != expected ? [ #throw("Assertion Mismatch: Values not the same, Expected: " + expected + ", Actual: " + actual) ]
    }
    
    assertNotSame(Object expected, Object actual) {
        actual == expected ? [ #throw("Assertion Mismatch: Values are the same, Not expected: " + expected + ", Actual: " + actual) ]
    }

    assertEquals(Object expected, Object actual) {
        actual !~ expected ? [ #throw("Assertion Mismatch: Values not equivalent, Expected: " + expected + ", Actual: " + actual) ]
    }

    assertNotEquals(Object expected, Object actual) {
        actual ~~ expected ? [ #throw("Assertion Mismatch: Values are equivalent, Not expected: " + expected + ", Actual: " + actual) ]
    }

    assertIsPresent(Object target) {
        target #isPresent ?! [ #throw("Assertion Mismatch: Instance is Nothing") ]
    }

    assertIsEmpty(Object target) {
        target #isEmpty ?! [ #throw("Assertion Mismatch: Instance is not Empty") ]
    }

    assertThrows(Closure closure, MetaClass<Throwable> expectedException) {
        [ closure #apply ]
            #catch [ t -> 
                (t #class == expectedException) ? [ ^ self ];
                #throw("Assertion Mismatch: Threw unexpected exception type") ];
        #throw("Assertion Mismatch: Expected exception was not thrown")
    }

    #> throw(String message) {
        AssertionSignal #new(message) #throw
    }

}