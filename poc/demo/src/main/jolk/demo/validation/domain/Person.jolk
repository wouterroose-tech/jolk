package demo.validation.domain;

///
/// @author Wouter Roose

final class Person {
    public Integer ssn;
    public String firstName;
    public String lastName;

    meta Person new() {
        ^ super #new
    }

    meta Person new(Integer ssn, String firstName, String lastName) {
        ^ super #new
            #ssn(ssn)
            #firstName(firstName)
            #lastName(lastName)
    }

    String name() {
        ^ self #firstName + " "+ self #lastName
    }

    String toString() {
        ^ "Person[ssn=" + self #ssn + ", firstName=" + self #firstName + ", lastName=" + self #lastName + "]"
    }
}