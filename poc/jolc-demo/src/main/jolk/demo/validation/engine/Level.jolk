package demo.validation.engine;

/// Issue Codes.
///
/// @author Wouter Roose

enum Level {

    // basic enum
    ERROR; WARNING; INFO; DEBUG;

    Boolean isError() { ^ self == ERROR }
    Boolean isWarning() { ^ self == WARNING }
    Boolean isInfo() { ^ self == INFO }
    Boolean isDebug() { ^ self == DEBUG }
    
    /// @Intrinsic("name") 
    /// final String name() {  }

    // enum with fields
    // ERROR("E");
    // WARNING("W");
    // INFO("I")

    ///private default by language rule
    ///String code

    /// default variadic constructor
    /// private Level Level(String c) { code = c }
    
    /// default valueOf methods
    /// static Level valueOf(String label) {}

    /// default accessor for enum fields
    /// String code() { ^code }
}