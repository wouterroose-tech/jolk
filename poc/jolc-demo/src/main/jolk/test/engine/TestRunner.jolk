~ jolk.test;

+ java.lang.System;

+ jolk.test.api.Test;
+ jolk.test.api.TestCase;
+ jolk.test.api.TestCase_Test;
+ jolk.test.api.TestSuite;
+ jolk.test.api.TestSuite_Test;
+ jolk.test.api.TestResult_Test;
+ examples.CircleTest;

/// # TestRunner
///
/// Simulates the JolkTestEngine for the JUnit test framework
///
/// @author Wouter Roose
///
class TestRunner {

    run() {
        // TODO 
        // 1. collect testsuites
        // 2. run tests, collect results
        
        System #out #println("Run Tests");
        System #out #println(">   " + "jolk.test.api");
        #runTestCase(TestCase_Test);
        // TODO finalize implementation of MetaClass #instanceProtocol
        // #runTestCase(TestSuite_Test);
        // #runTestCase(TestResult_Test);
        // #runTestCase(CircleTest);
    }
    
    runTestCase(MetaClass<TestCase> testClass) {
        System #out #println(">>  " + testClass #name);
        testClass
            #instanceProtocol
            #forEach[ s ->
                TestResult result = testClass #new #selector(s) #run;
                System #out #println(">>> " + s + " -> " + result #result);
            ]
    }
}