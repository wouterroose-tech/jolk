~ test.validation.rules;

+ demo.validation.domain.Person;
+ demo.validation.domain.ContactForm;

///
/// @author Wouter Roose

class ContactFormTest {

    Boolean testNew() {
        ^ ContactForm #new #isPresent
    }

    Boolean testNewCompleted() {
        Person person = #getPerson;
        ContactForm #new
            #person(person)
            #email("john.doe@example.com")
            #zipCode(12345)
            #description("Test description")
            #ifPresent [ f ->
                ^ (f #person == person)
                    && (f #email ~~ "john.doe@example.com")
                    && (f #zipCode == 12345)
                    && (f #description ~~ "Test description")
                ];
        ^ false
    }

    // Form should be identical to itself.
    Boolean testEquality1() {
        
        ContactForm form = ContactForm #new
            #person(#getPerson)
            #email("john.doe@example.com")
            #zipCode(12345)
            #description("Test description");
        ^ form == form
    }

    // Distinct forms should not be identical.
    Boolean testEquality2() {
        
        ContactForm formA = ContactForm #new
            #person(#getPerson)
            #email("john.doe@example.com")
            #zipCode(12345)
            #description("Test description");
        ContactForm formB = ContactForm #new
            #person(#getPerson)
            #email("john.doe@example.com")
            #zipCode(12345)
            #description("Test description");
        ^ formA != formB
    }

    // Form should be equivalent to itself.
    Boolean testEquivalence1() {
        
        ContactForm form = ContactForm #new
            #person(#getPerson)
            #email("john.doe@example.com")
            #zipCode(12345)
            #description("Test description");
        ^ form ~~ form
    }

    // Forms with equivalent persons and matching data should be equivalent.
    Boolean testEquivalence2() {
        
        ContactForm formA = ContactForm #new
            #person(#getPerson)
            #email("john.doe@example.com")
            #zipCode(12345)
            #description("Test description");
        ContactForm formB = ContactForm #new
            #person(#getPerson)
            #email("john.doe@example.com")
            #zipCode(12345)
            #description("Test description");
        ^ formA ~~ formB
    }
    
    // Forms with different data should not be equivalent.
    Boolean testEquivalence3() {

        ContactForm formA = ContactForm #new
            #person(#getPerson)
            #email("john.doe@example.com")
            #zipCode(12345)
            #description("Test description A");
        ContactForm formB = ContactForm #new
            #person(#getPerson)
            #email("john.doe@example.com")
            #zipCode(12345)
            #description("Test description B");
        ^ formA !~ formB
    }

    #> Person getPerson() {
        ^ Person #new
            #ssn(12345678939)
            #firstName("John")
            #lastName("Doe");
    }

}