~ examples;

+ java.lang.IllegalArgumentException;
+ jolk.test.api.TestCase;

& examples.Complex.NaN;

///
/// @author Wouter Roose
///
class ComplexTest extends TestCase {

    testNew() {
        Complex complex = Complex #new(1.0, 2.0);
        #assertIsPresent(complex);
        #assertEquals(1.0 #asDouble, complex #real);
        #assertEquals(2.0 #asDouble, complex #imaginary);
    }

    testAdd() {
        Complex c1 = Complex #new(1.0, 2.0);
        Complex c2 = Complex #new(3.0, 4.0);
        Complex result = c1 + c2;
        #assertEquals(4.0 #asDouble, result #real);
        #assertEquals(6.0 #asDouble, result #imaginary);
        // Test addition with NaN values
        #assertEquals(NaN, c1 + NaN);
    }

    testSubtract() {
        Complex c1 = Complex #new(5.0, 6.0);
        Complex c2 = Complex #new(2.0, 3.0);
        Complex result = c1 - c2;
        #assertEquals(3.0 #asDouble, result #real);
        #assertEquals(3.0 #asDouble, result #imaginary);
        // Test addition with NaN values
        #assertEquals(NaN, c1 - NaN);
    }

    testToString() {
        Complex complex = Complex #new(1.0, 2.0);
        #assertEquals("1.0 + 2.0i", complex #toString);
        // Test addition with NaN values
        #assertEquals("NaN + NaNi", NaN #toString);
    }

    testEquivalence() {
        Complex c1 = Complex #new(1.0, 2.0);
        Complex c2 = Complex #new(1.0, 2.0);
        Complex c3 = Complex #new(2.0, 3.0);
        #assertThat(c1 ~~ c1);
        #assertThat(c1 ~~ c2);
        #assertThat(!(c1 ~~ c3));
        // Test addition with NaN values
        #assertThat(NaN == NaN);
        #assertThat(NaN ~~ NaN);
        #assertThat(!(c1 ~~ NaN));
        #assertThat(!(NaN ~~ c1));
    }

}