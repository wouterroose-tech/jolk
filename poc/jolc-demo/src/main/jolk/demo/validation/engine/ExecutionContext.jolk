package demo.validation.engine;

using java.util.ArrayList;
using java.util.function.Predicate;

/// # ExecutionContext
///
/// This class carries state during validation and collects issues.
///
/// @author Wouter Roose

class ExecutionContext {

    ArrayList<Issue> issues;

    meta new() {
        ^super #new #issues(#[])
    }

    /// Adds an issue for the given subject.
    Self add(Object subject, Issue issue) {
        self #issues #add(issue)
    }

    /// Returns true if any issue has been reported.
    Boolean hasIssue() {
        ^ !self #issues #isEmpty
    }
    
    /// Returns true if any error has been reported.
    Boolean hasError() {
        ^ self #hasMatch [ i -> i #level #isError ]
    }

    /// Returns true if any warning has been reported.
    Boolean hasWarning() {
        ^ self #hasMatch [ i -> i #match(WARNING) ]
    }

    /// Returns true if any issue was reported for the given subject.
    Boolean hasIssue(Object subject) {
        ^ self #hasMatch [ i -> i #concerns(subject)]
    }

    private Boolean hasMatch(Predicate<Issue> p) {
        ^ issues #anyMatch(p)
    }

}