 ~ demonstrators;

& java.lang.Math.PI;
& TWO_PI = java.lang.Math.TAU;

/// # MetaFieldProjectionDemonstrator
///
/// Demonstrates Meta-Level Projection lenses to access host constants directly.

final class MetaFieldProjectionDemonstrator {

    Double calculateCircumference(Double radius) {
        ^ radius * TWO_PI
    }

    Double calculateArea(Double radius) {
        ^ PI * (radius ** 2)
    }
    
}