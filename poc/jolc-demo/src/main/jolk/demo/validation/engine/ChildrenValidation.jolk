package demo.validation.engine;

using java.util.function.Function;

using java.util.List;
using java.util.concurrent.StructuredTaskScope;
using java.util.concurrent.StructuredTaskScope.Joiner;
using java.util.function.Function;

using java.lang.foreign.MemorySegment.Scope;

/// # ChildrenValidation
/// Validation node that visits and validates a collection of child elements from the subject.
///
/// Iterates over children provided by a supplier and applies validation rules to each.
/// Internal to the validation engine. Final by design.
///
/// - **R**: The domain object type of the supplied children.
///
/// @author Wouter Roose

package final class ChildrenValidation<T, R> extends Node<T> {

    Function<T, List<R>> supplier;
    Validation<R> validation;

    /// ## accept
    /// Propagates the validation to each of the subject's children provided by the supplier.
    @Override
    accept(T subject, E executionContext) {
        self #delegate(supplier #apply(subject), executionContext);
    }

    private delegate(List<R> children, E executionContext) {
        /*
        children #isEmpty [^self];
        [ StructuredTaskScope #open(Joiner #allSuccessfulOrThrow) ]
            #try [ scope ->
                children #forEach [child -> scope #fork [validation #accept(child, executionContext) ] ];
                scope #join ]
            #catch [ InterruptedException e ->
                Thread #currentThread #interrupt;
                RuntimeException #new("Validation interrupted.", e) #throw ]
        */
        children #forEach [child -> validation #accept(child, executionContext) ]
    }
}