~ demonstrators;

+ java.util.List;
+ jolk.test.api.TestCase;

///
/// @author Wouter Roose
///
public class CoreCollectionDemonstratorTest extends TestCase {

    CoreCollectionDemonstrator demonstrator = CoreCollectionDemonstrator #new;

    testRunArrayNew() {
        List<String> list = demonstrator #runArrayNew;
        #assertIsPresent(list);
        #assertEquals(3, list #size);
        #assertEquals("red", list #at(0));
    }

    testRunArrayNewLiteral() {
        List<String> list = demonstrator #runArrayLiteral;
        #assertIsPresent(list);
        #assertEquals(3, list #size);
        #assertEquals("red", list #at(0));
    }

