~ jolk.test.engine;

+ java.lang.String;
+ java.lang.System;
+ java.util.List;
+ jolk.test.api.Test;
+ jolk.test.api.TestCase;
+ jolk.test.api.TestCase_Test;
+ jolk.test.api.TestSuite;
+ jolk.test.api.TestSuite_Test;
+ jolk.test.api.TestResult;
+ jolk.test.api.TestResult_Test;
+ jolk.test.engine.TestRunner_Test;

/// # TestRunner
///
/// a Basic test runner.
///
/// Simulates the JolkTestEngine for the JUnit test framework
///
/// @author Wouter Roose
///
class TestRunner {

    run() {
        System #out #println("    Run All Tests");
        System #out #println("    -------------");
        System #out #println(">   " + "jolk.test.api");
        #runTestCase(TestCase_Test);
        #runTestCase(TestSuite_Test);
        #runTestCase(TestResult_Test);
        #runTestCase(TestRunner_Test);
    }
    
    runTestCase(MetaClass<TestCase> testClass) {
        System #out #println(">>  " + testClass #name);
        
        [ 
            testClass #beforeAll;
            #selectors(testClass)
                #forEach[ s ->
                    TestResult result = #runTest(testClass #new, s);
                    System #out #println(">>> " + s + " -> " + result #result);
                ];
            testClass #afterAll
        ] #catch [
            e -> ^ TestResult #failed(e)
        ]
    }

    List<String> selectors(MetaClass<TestCase> testClass) {
        // TODO in future releases protocol will return Selector
        // -> filter public methods
        // -> filter methods with @Test annotation

        // TODO replace with filter once implemented for ArrayExtension in the Jolk engine
        // ^ #instanceProtocol #filter [ s -> s #startWith("test)")]
        List<String> testSelectors = #[];
        testClass
            #instanceProtocol
            #forEach [ s -> 
                s #startsWith("test") ? [ testSelectors #add(s)]
            ];
        ^ testSelectors
    }

    TestResult runTest(TestCase test, String selector) {
        test #beforeEach;
        [
            test #project(selector);
            ^ TestResult #success
        ] #catch [
            e -> ^ #handle(e)
        ] #finally [
            test #afterEach
        ]
    }

    #> handle(RuntimeExecption e) {
        // Exception type verified catch not yet implemented
        (e #getMessage == "DISABLED") ? [ e ->  ^ TestResult #disabled ];
        (e #getMessage == "FAILURE") ?  [ e -> ^ TestResult #failed(e) ];
        ^ TestResult #fault(e)
    }

}