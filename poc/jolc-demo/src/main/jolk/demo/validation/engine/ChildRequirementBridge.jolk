package demo.validation.engine;

using java.util.function.Function;

/// # ChildRequirementBridge
///
/// The Bridge implementation for the Pivot Pattern in the Validation Framework.
/// This class encapsulates the transitional state between a Sovereign (`ValidationSuite`)
/// and a Requirement (`ChildRequirement`), holding the extraction logic (`supplier`)
/// until the requirement is fulfilled.
///
/// @author Wouter Roose

package final class ChildRequirementBridge<T, R> implements ChildRequirement<T, R> {

    ValidationSuite<T> master;
    Function<T, R> supplier;

    package meta ChildRequirementBridge<T, R> new(ValidationSuite<T> master, Function<T, R> supplier) {
        ^ super #new #master(master) #supplier(supplier)
    }

    final ValidationSuite<T> add(Validation<R> validation) {
        // Construct the internal node and revert to master
        self #master #add(ChildValidation<T, R> #new(supplier, validation))
    }
}
