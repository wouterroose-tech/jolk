~ jolk.examples;

+ examples.Circle;
+ java.lang.IllegalArgumentException;

+ jolk.test.api.TestCase;
+ jolk.test.api.Assert;

///
/// @author Wouter Roose
///
class CircleTest extends TestCase {

    testNew() {
        Double radious = 5.0;
        Circle circle = Circle #new(5);
        #assertIsPresent(circle);
        #assertEquals(radious, circle #radius)
    }

    testDiameter() {
        #disabled; // lazy fields are not yet supported
        #assertEquals(10, circle #diameter)
    }

    testArea() {
        Double area = Circle #new(5) #area;
        #assertEquals(78.53981633974483 #asDouble, area);
    }

    testCircumference() {
        Circle circle = Circle #new(5.0);
        #assertEquals(31, circle #circumference #round);
    }

    testToString() {
        #assertEquals("Circle[radius=5.0]", Circle #new(5) #toString)
    }

    testScaling() {
        #assertEquals(10 #asDouble, (Circle #new(5) * 2) #radius)
    }

    testEquivalence() {
        #assertThat(Circle #new(5) ~~ Circle #new(5.0))
    }

    testInvalidConstruction() {
        #assertThrows([Circle #new(-1.0)], IllegalArgumentException )
    }
}