~ jolk.test;

+ java.lang.System;

+ jolk.test.api.Test;
+ jolk.test.api.TestCase;
+ jolk.test.api.TestCase_Test;
+ jolk.test.api.TestSuite;
+ jolk.test.api.TestSuite_Test;
+ jolk.test.api.TestResult_Test;
+ jolk.examples.CircleTest;
+ jolk.demonstrators.ArchetypeClassDemonstratorTest;
+ jolk.demo.validation.domain.PersonTest;
+ jolk.demo.validation.domain.ContactFormTest;
+ jolk.demo.validation.engine.IssueTest;
+ jolk.demo.validation.engine.LevelTest;
+ jolk.demo.validation.rules.ContactFormValidationTest;
+ jolk.demo.validation.rules.SsnConstraintTest;
+ jolk.demo.validation.rules.ZipConstraintTest;

/// # TestRunner
///
/// Simulates the JolkTestEngine for the JUnit test framework
///
/// @author Wouter Roose
///
class TestRunner {

    run() {
        // TODO collect testsuites, run tests & sout result
        
        System #out #println("    Run All Tests");
        System #out #println("    -------------");
        System #out #println(">   " + "jolk.test.api");
        #runTestCase(TestCase_Test);
        #runTestCase(TestSuite_Test);
        #runTestCase(TestResult_Test);
        System #out #println(">   " + "examples");
        #runTestCase(CircleTest);
        System #out #println(">   " + "demonstrators");
        #runTestCase(ArchetypeClassDemonstratorTest);
        // add more demonstrators
        System #out #println(">   " + "demo.validation.domain");
        #runTestCase(PersonTest);
        #runTestCase(ContactFormTest);
        System #out #println(">   " + "demo.validation.engine");
        #runTestCase(LevelTest);
        #runTestCase(IssueTest);
        // add tests for each engine class
        System #out #println(">   " + "demo.validation.rules");
        #runTestCase(ZipConstraintTest);
        #runTestCase(SsnConstraintTest);
        #runTestCase(ContactFormValidationTest);
    }
    
    runTestCase(MetaClass<TestCase> testClass) {
        System #out #println(">>  " + testClass #name);
        testClass
            #testProtocol
            #forEach[ s ->
                TestResult result = testClass #new #selector(s) #run;
                System #out #println(">>> " + s + " -> " + result #result);
            ];
    }
}