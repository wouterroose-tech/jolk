~ jolk.demo.validation.domain;

+ demo.validation.domain.Person;

+ jolk.test.api.TestCase;
+ jolk.test.api.Assert;

/// # PersonTest
///
/// @author Wouter Roose
///
class PersonTest extends TestCase {

    testPersonCreation() {
        Person person = Person #new
            #ssn(12345678939)
            #firstName("John")
            #lastName("Doe");
        #assertSame(12345678939, person #ssn);
        #assertEquals("John", person #firstName);
        #assertEquals("Doe", person #lastName);
        #assertEquals("John Doe", person #name);
    }

    testPersonEquality() {
        Person p1 = Person #new
            #ssn(12345678939)
            #firstName("John")
            #lastName("Doe");
        Person p2 = Person #new
            #ssn(12345678939)
            #firstName("John")
            #lastName("Doe");
        
        #assertSame(p1, p1);
        #assertThat(p1 != p2);
    }

    testPersonEquivalence() {
        Person p1 = Person #new
            #ssn(12345678939)
            #firstName("John")
            #lastName("Doe");
        Person p2 = Person #new
            #ssn(12345678939)
            #firstName("John")
            #lastName("Doe");
        Person p3 = Person #new
            #ssn(987654321)
            #firstName("Jane")
            #lastName("Smith");
        
        #assertEquals(p1, p1);
        #assertEquals(p1, p2);
        #assertThat(p1 !~ p3);
    }

}