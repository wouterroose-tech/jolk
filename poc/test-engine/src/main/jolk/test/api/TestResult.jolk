~ jolk.test.api;

+ java.lang.RuntimeException;

& jolk.test.api.TestStatus.SUCCESS;
& jolk.test.api.TestStatus.ERROR;
& jolk.test.api.TestStatus.FAILURE;

/// # TestResult
///
/// TODO
///
/// @author Wouter Roose
///
class TestResult {

    String result;

    TestStatus status;

    meta success() {
        ^ #new
            #status(TestStatus #SUCCESS)
            #result("success")
    }

    meta fault(RuntimeException e) {
        ^ #new
            #status(TestStatus #FAULT)
            #result("fault: " + e #getMessage)
    }

    meta failed(RuntimeException e) {
        ^ #new
            #status(TestStatus #FAILURE)
            #result("failure: " + e #getMessage)
    }

    meta disabled() {
        ^ #new
            #status(TestStatus #DISABLED)
            #result("disabled")
    }
}