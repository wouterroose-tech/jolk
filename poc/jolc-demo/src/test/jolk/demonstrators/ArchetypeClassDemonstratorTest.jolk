~ demonstrators;

+ jolk.test.api.TestCase;

///
/// @author Wouter Roose
///
final class ArchetypeClassDemonstratorTest extends TestCase {
    
    testBasicNew() {
        Person p = ArchetypeClassDemonstrator #new #runBasicNew;
        #assertIsPresent(p);
        #assertThat(p != null);
    }

    testRunCanonicalNew() {
        Person p = ArchetypeClassDemonstrator #new #runCanonicalNew;
        #assertEquals(123456789, p #ssn);
        #assertEquals("John", p #firstName);
        #assertEquals("Doe", p #lastName);
    }

    testRunFluid() {
        String s = ArchetypeClassDemonstrator #new #runFluid;
        #assertEquals("Jane Doe", s);
    }

    testRunVariable() {
        String s = ArchetypeClassDemonstrator #new #runVariable;
        #assertEquals("Jane", s);
    }
    
    testRunConstant() {
        String s = ArchetypeClassDemonstrator #new #runConstant;
        #assertEquals("Jane", s);
    }
    
    testRunToString() {
        String s = ArchetypeClassDemonstrator #new #runToString;
        #assertEquals("Person[ssn=123456789, firstName=John, lastName=Doe]", s);
    }

}